# ─── Spidercrawl Environment ─────────────────────────────────────

# Server
PORT=3200
HOST=0.0.0.0
NODE_ENV=development
REQUIRE_API_KEY=false
MAX_CONCURRENT_CRAWLS=10
API_RATE_LIMIT_MAX=1000
API_RATE_LIMIT_WINDOW=1 minute

# Redis (for BullMQ job queue)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
CRAWL_EXECUTION_MODE=auto
CRAWL_QUEUE_FALLBACK_MS=5000
STALE_QUEUED_JOB_MS=600000

# Python Worker
WORKER_HOST=127.0.0.1
WORKER_PORT=8400
WORKER_URL=

# AI Providers (set at least one)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.0-flash-001
OPENAI_API_KEY=
GOOGLE_AI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Proxy (used in Phase 3+)
PROXY_URL=
PROXY_ROTATION_ENABLED=false

# Database (Phase 4: Postgres + pgvector)
DATABASE_URL=postgresql://spidercrawl:spidercrawl@localhost:5432/spidercrawl

# RAG / Embeddings (Phase 4)
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# ─── Observability ────────────────────────────────────────────────
# Sentry — sentry.io → Project Settings → Client Keys → DSN
SENTRY_DSN=

# ─── Billing & Payments ───────────────────────────────────────────
# Stripe — dashboard.stripe.com → Developers → API keys
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# dashboard.stripe.com → Products → Add product → copy price ID
STRIPE_PRICE_STARTER=price_
STRIPE_PRICE_PRO=price_

# ─── Auth & Email ─────────────────────────────────────────────────
# Public URL of your deployed API (used in emails and quota error messages)
APP_URL=https://your-railway-app.up.railway.app
# Resend — resend.com → API Keys
RESEND_API_KEY=
# From address for welcome emails (must be a verified domain in Resend)
FROM_EMAIL=noreply@yourdomain.com

# ─── SSE Replay ───────────────────────────────────────────────────
SSE_REPLAY_LIMIT=100
