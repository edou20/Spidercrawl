# ─── Spidercrawl Environment ─────────────────────────────────────

# Server
PORT=3200
HOST=0.0.0.0
NODE_ENV=development
REQUIRE_API_KEY=false
MAX_CONCURRENT_CRAWLS=10
API_RATE_LIMIT_MAX=1000
API_RATE_LIMIT_WINDOW=1 minute

# Redis (for BullMQ job queue)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
# Railway / managed Redis: set this instead of REDIS_HOST (takes precedence)
REDIS_URL=
CRAWL_EXECUTION_MODE=auto
CRAWL_QUEUE_FALLBACK_MS=5000
STALE_QUEUED_JOB_MS=600000

# Python Worker
WORKER_HOST=127.0.0.1
WORKER_PORT=8400
WORKER_URL=

# AI Providers (used in Phase 2+)
# OpenRouter: put your sk-or-v1 key in OPENAI_API_KEY and set:
#   OPENAI_BASE_URL=https://openrouter.ai/api/v1
#   OPENAI_CHAT_MODEL=openai/gpt-4o-mini   (or another OpenRouter model slug)
# Optional OpenRouter attribution: OPENROUTER_HTTP_REFERER, OPENROUTER_APP_TITLE
# If GOOGLE_AI_API_KEY is set, Gemini is used first; unset it to force the OpenAI-compatible path.
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_CHAT_MODEL=
OPENROUTER_HTTP_REFERER=
OPENROUTER_APP_TITLE=
ANTHROPIC_API_KEY=
GOOGLE_AI_API_KEY=

# Sentry
SENTRY_DSN=https://89deee47ab51643614f92c5ba736da5f@o4511374317060096.ingest.us.sentry.io/4511374342750208
VITE_SENTRY_DSN=https://548b227a2a4616e720eba8c5b4143a9f@o4511374317060096.ingest.us.sentry.io/4511374353498112

# Proxy (used in Phase 3+)
PROXY_URL=
PROXY_ROTATION_ENABLED=false

# Database (Phase 4: Postgres + pgvector)
DATABASE_URL=postgresql://spidercrawl:spidercrawl@localhost:5432/spidercrawl

# RAG / Embeddings (Phase 4)
# If OPENAI_BASE_URL points to OpenRouter, use an embedding model slug that OpenRouter supports for EMBEDDING_MODEL.
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# ─── Auth / billing / email (launch guide) ─────────────────────
APP_URL=http://127.0.0.1:3200
RESEND_API_KEY=
FROM_EMAIL=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
PAGES_QUOTA_FREE=10000
PAGES_QUOTA_STARTER=100000
PAGES_QUOTA_PRO=500000
DATABASE_KEEPALIVE_MS=86400000
DISABLE_DATABASE_KEEPALIVE=false
