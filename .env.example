# ─── Spidercrawl Environment ─────────────────────────────────────

# Server
PORT=3200
HOST=0.0.0.0
NODE_ENV=development
REQUIRE_API_KEY=false
MAX_CONCURRENT_CRAWLS=10
API_RATE_LIMIT_MAX=1000
API_RATE_LIMIT_WINDOW=1 minute

# Redis (for BullMQ job queue)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
CRAWL_EXECUTION_MODE=auto
CRAWL_QUEUE_FALLBACK_MS=5000
STALE_QUEUED_JOB_MS=600000

# Python Worker
WORKER_HOST=127.0.0.1
WORKER_PORT=8400
WORKER_URL=

# AI Providers (used in Phase 2+)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_AI_API_KEY=

# Proxy (used in Phase 3+)
PROXY_URL=
PROXY_ROTATION_ENABLED=false

# Database (Phase 4: Postgres + pgvector)
DATABASE_URL=postgresql://spidercrawl:spidercrawl@localhost:5432/spidercrawl

# RAG / Embeddings (Phase 4)
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536
