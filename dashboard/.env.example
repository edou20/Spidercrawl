# ─── Dashboard Environment ────────────────────────────────────────
# All VITE_ vars are embedded at build time and visible in the browser.
# Never put secret keys here.

# URL of the Spidercrawl API backend
# Leave empty when dashboard is served from the same origin as the API
VITE_BACKEND_URL=

# Docs site URL (shown in the nav bar)
VITE_DOCS_URL=

# Sentry — dashboard.sentry.io → Project (React) → Settings → Client Keys → DSN
VITE_SENTRY_DSN=
