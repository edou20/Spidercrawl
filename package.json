{
  "name": "spidercrawl",
  "version": "0.1.0",
  "description": "AI-native web intelligence engine — multimodal crawling, goal-oriented extraction, and self-healing scraping.",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src/",
    "test": "vitest",
    "verify": "npm run build && npm run lint && npm test -- --run && npm run dashboard:build && npm run sdk:build && npm run python:check",
    "dashboard:install": "npm --prefix dashboard install",
    "dashboard:dev": "npm --prefix dashboard run dev",
    "dashboard:build": "npm --prefix dashboard run build",
    "worker:install": "python3 -m pip install -r workers/requirements.txt && python3 -m playwright install chromium",
    "worker:dev": "python3 workers/scraper_worker.py",
    "sdk:build": "npm --prefix sdk/typescript run build",
    "python:check": "python3 -m py_compile sdk/python/spidercrawl/*.py workers/scraper_worker.py",
    "db:migrate": "psql \"$DATABASE_URL\" -f db/schema.sql",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docs:install": "npm --prefix docs install",
    "docs:dev": "npm --prefix docs run dev",
    "docs:build": "npm --prefix docs run build",
    "docs:preview": "npm --prefix docs run preview"
  },
  "keywords": [
    "crawler",
    "scraper",
    "ai",
    "llm",
    "rag",
    "markdown"
  ],
  "license": "MIT",
  "dependencies": {
    "@fastify/cors": "^11.0.1",
    "@fastify/rate-limit": "^10.2.2",
    "@fastify/static": "^9.1.3",
    "@google/generative-ai": "^0.24.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@types/pg": "^8.20.0",
    "bullmq": "^5.34.8",
    "cheerio": "^1.0.0",
    "cron-parser": "^5.5.0",
    "dotenv": "^16.5.0",
    "fastify": "^5.3.3",
    "fastify-raw-body": "^5.0.0",
    "ioredis": "^5.6.1",
    "nanoid": "^5.1.5",
    "openai": "^6.34.0",
    "pg": "^8.20.0",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "stripe": "^22.1.1",
    "turndown": "^7.2.0",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^22.14.1",
    "@types/turndown": "^5.0.5",
    "eslint": "^9.25.1",
    "globals": "^17.6.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.59.1",
    "vitest": "^3.1.3"
  }
}
